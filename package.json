{
  "name": "raw-ts",
  "version": "0.0.6",
  "main": "./dist/lsp/index.js",
  "description": "A compile-time, C-like, low-level type and memory management system for TypeScript",
  "scripts": {
    "build": "tspc",
    "watch": "tspc -w"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    "./compiler": {
      "types": "./dist/compiler/index.d.ts",
      "default": "./dist/compiler/index.js"
    },
    "./lsp": {
      "types": "./dist/lsp/index.d.ts",
      "default": "./dist/lsp/index.js"
    },
    "./macros": {
      "types": "./dist/macros/index.d.ts",
      "default": "./dist/macros/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./std": {
      "types": "./dist/std/index.d.ts",
      "default": "./dist/std/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "raw-ts": "file:.",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.3.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spasimir21/raw-ts.git"
  },
  "homepage": "https://github.com/spasimir21/raw-ts/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/spasimir21/raw-ts/issues"
  },
  "keywords": [
    "struct",
    "lsp",
    "transformer",
    "c-like",
    "low-level",
    "memory-management"
  ],
  "author": "Spasimir Pavlov",
  "license": "MIT"
}
